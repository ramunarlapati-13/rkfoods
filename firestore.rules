rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin check via custom claim — set via Firebase Admin SDK
      // Run: admin.auth().setCustomUserClaims(uid, { admin: true })
      return isSignedIn() && request.auth.token.admin == true;
    }

    function validOrderData() {
      let data = request.resource.data;
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status',
                                  'customerName', 'customerPhone', 'customerEmail',
                                  'shippingAddress', 'createdAt'])
          && data.userId is string
          && data.totalAmount is number
          && data.totalAmount > 0
          && data.status == 'pending';  // New orders must start as 'pending'
    }

    function validReviewData() {
      let data = request.resource.data;
      return data.keys().hasAll(['productId', 'userId', 'rating', 'comment', 'createdAt'])
          && data.rating >= 1 && data.rating <= 5
          && data.comment.size() <= 1000
          && data.userId == request.auth.uid;
    }

    // ── Products ──────────────────────────────────────────────────
    // Anyone can read; only admins can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────
    // Users can create their own orders; read their own orders; admins manage all
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && validOrderData();
      allow update: if isAdmin();  // Only admins can change status, add tracking
      allow delete: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────
    // Anyone can read; authenticated users can create their own; admins can delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && validReviewData();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────
    // Users can read and write only their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // ── Locations ─────────────────────────────────────────────────
    // Anyone can read; only admins can manage
    match /locations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Deny everything else by default ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

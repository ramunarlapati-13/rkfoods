rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
          && request.resource.size < 5 * 1024 * 1024;  // Max 5 MB
    }

    function isValidVideo() {
      return request.resource.contentType.matches('video/.*')
          && request.resource.size < 50 * 1024 * 1024; // Max 50 MB
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
          && request.resource.size < 10 * 1024 * 1024; // Max 10 MB
    }

    // ── User Review Uploads ───────────────────────────────────
    // Path: /reviews/{userId}/images/{fileName}
    match /reviews/{userId}/images/{fileName} {
      allow read: if true;   // Public read for review display
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isValidImage();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // Path: /reviews/{userId}/videos/{fileName}
    match /reviews/{userId}/videos/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isValidVideo();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // Path: /reviews/{userId}/audio/{fileName}
    match /reviews/{userId}/audio/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isValidAudio();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // ── Product Images (admin-only upload) ────────────────────
    match /products/{fileName} {
      allow read: if true;    // Public — needed for product cards
      allow write: if isAdmin();
    }

    // ── Banner / Hero Media (admin-only) ──────────────────────
    match /banners/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
